# Copia este fichero como ".env" para ejecutar en local (opcional).
# En producción (Render) define estas variables en el panel del servicio.

# Puerto local (opcional)
PORT=3000

# Contraseña del modo Admin (la persona que va a la compra).
# CÁMBIALA por una tuya antes de usarla en serio.
ADMIN_PASSWORD=shoply

# Base de datos permanente (PostgreSQL). Si la defines, los datos NO se borran
# nunca. Consíguela gratis en https://neon.tech (cadena de conexión).
# Si la dejas vacía, se usa un fichero local TEMPORAL (se borra al reiniciar).
# DATABASE_URL=postgresql://usuario:password@host/basedatos?sslmode=require

# Contacto para las notificaciones push (cámbialo por tu email)
VAPID_SUBJECT=mailto:tu-email@example.com

# Claves de notificaciones push (OPCIONALES).
# Si las dejas vacías, el servidor genera unas automáticamente la primera vez.
# Para fijarlas tú, genera un par con:  npm run keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
